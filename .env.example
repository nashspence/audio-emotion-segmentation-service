SERVICE_PORT=8000
LOG_LEVEL=info
HF_TOKEN=
HF_HOME=/models/huggingface
MODEL_DEVICE=cuda:0
MODEL_USE_HALF_PRECISION=false
MODEL_BATCH_SIZE=8
MODEL_SAMPLE_RATE_HZ=16000
WINDOW_SECONDS=4.0
HOP_SECONDS=1.0
SMOOTHING_SECONDS=1.5
SEGMENT_RESOLUTION_SECONDS=0.5
MIN_SEGMENT_SECONDS=1.0
MERGE_GAP_SECONDS=0.25
STARTUP_TIMEOUT_SECONDS=1800
CATEGORICAL_MODEL_ID=3loi/SER-Odyssey-Baseline-WavLM-Categorical
AVD_MODEL_ID=3loi/SER-Odyssey-Baseline-WavLM-Multi-Attributes
API_BASE_URL=http://host.docker.internal:8000
